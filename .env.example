SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg2://maristmaps:maristmaps@127.0.0.1:5432/maristmaps

# Public URL of the Martin tile server as seen from the browser. The client
# appends /<table>/{z}/{x}/{y} to this for each planet_osm_* source.
MARTIN_PUBLIC_URL=http://127.0.0.1:3000

# Marist College campus (Poughkeepsie, NY).
MAP_CENTER_LON=-73.93446921913481
MAP_CENTER_LAT=41.72233476143977
MAP_ZOOM=16.5

# Used by scripts/load-osm.sh when invoking osm2pgsql. PG* vars also feed
# pg_isready, psql, and the docker fallback container.
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=maristmaps
PGPASSWORD=maristmaps
PGDATABASE=maristmaps
PBF_FILE=pbf/campus.osm.pbf
OSM2PGSQL_CACHE=512
# OSM2PGSQL_EXTRA=--number-processes 4
# OSM2PGSQL_IMAGE=iboates/osm2pgsql:latest
