# ----------------------------------------------------------------------
# Secrets — REQUIRED in prod, safe-ish defaults in dev
# ----------------------------------------------------------------------

# Flask session signing key. Dev default is fine for local tinkering;
# in prod generate with:  openssl rand -hex 32
SECRET_KEY=change-me

# OpenAI key used by the langchain agent (agent/service.py).
# Dev: your personal key. Prod: a scoped project key with a spend cap.
OPENAI_API_KEY=change-me

# ----------------------------------------------------------------------
# Production only — used by deploy/docker-compose.prod.yml + docker/Caddyfile
# ----------------------------------------------------------------------

# Subdomain where maristmaps will live. An A/AAAA record for this name
# must already point at this VPS before Caddy can fetch a cert.
DOMAIN=maps.example.com

# Email Let's Encrypt registers with (expiry-renewal notices, abuse contact).
ACME_EMAIL=you@example.com

# ----------------------------------------------------------------------
# App config
# ----------------------------------------------------------------------

# Public URL of the Martin tile server as seen from the BROWSER.
# Dev (flask on host, martin on localhost:3000):
#   MARTIN_PUBLIC_URL=http://127.0.0.1:3000
# Prod (Caddy proxies /tiles/* to martin):
#   MARTIN_PUBLIC_URL=https://${DOMAIN}/tiles
MARTIN_PUBLIC_URL=http://127.0.0.1:3000

# Marist + Vassar + central Poughkeepsie extract (Poughkeepsie, NY).
MAP_CENTER_LON=-73.90665154393827
MAP_CENTER_LAT=41.69664534616691
MAP_ZOOM=12.6
# Optional explicit render bounds (west,south,east,north). When set, the map
# clamps to this bbox (with a tiny visual pad) so the whole PBF renders without
# panning into blank regions outside the extract.
MAP_RENDER_BBOX=-73.95637680919867,41.6635939943537,-73.85692627867788,41.729696697980124

# Clip buildings / POIs / routing graph to this radius (meters) around
# MAP_CENTER_{LON,LAT}. Keeps /api/features + route graph fast even when
# the imported PBF covers a much larger area. Set to 0 to disable.
MAP_FEATURE_RADIUS_M=6000

# Set to 1 to block Flask startup until the routing graph cache is built.
# Useful on larger extracts where you prefer startup latency over first-route lag.
ROUTING_WARM_SYNC=0

# Cap how many entrance-pair outdoor candidates trip planning evaluates for
# building-to-building routes. Lower = faster responses, higher = potentially
# slightly better optimality in dense entrance datasets.
TRIP_MAX_OUTDOOR_CANDIDATES=24

# Agent: optional sassy persona; log level INFO/DEBUG/WARNING.
AGENT_BITCH_MODE=0
AGENT_LOG_LEVEL=INFO
MARISTMAPS_LOG_LEVEL=INFO

# ----------------------------------------------------------------------
# Gunicorn (prod web service)
# ----------------------------------------------------------------------

# 2 workers × 4 threads fits a 1-2 GB / 1-2 vCPU VPS. Bump on bigger
# boxes or if you see request queueing in the gunicorn access log.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ----------------------------------------------------------------------
# Database — matches docker-compose.yml defaults. Change POSTGRES_PASSWORD
# in prod (and the password in DATABASE_URL / MARTIN's env inherits it).
# ----------------------------------------------------------------------

POSTGRES_USER=maristmaps
POSTGRES_PASSWORD=maristmaps
POSTGRES_DB=maristmaps

# Used by the init container (osm2pgsql + db/load_data.py) and by
# host-side tooling like psql. db/load_data.py reads DATABASE_URL
# directly; app/__init__.py reads it with the +psycopg2 dialect.
DATABASE_URL=postgresql+psycopg2://maristmaps:maristmaps@127.0.0.1:5432/maristmaps

# ----------------------------------------------------------------------
# OSM import (init container)
# ----------------------------------------------------------------------

# PBF filename inside ./pbf. The init container mounts ./pbf:/app/pbf:ro.
PBF_BASENAME=campus.osm.pbf

# osm2pgsql --cache in MB. Raise on big PBFs, lower on tight VPS RAM.
OSM2PGSQL_CACHE=512
# OSM2PGSQL_EXTRA=--number-processes 4

# Set to 1 to force osm2pgsql to re-import even if planet_osm_* tables
# already have rows. Otherwise init skips the import on repeat runs.
FORCE_OSM=0

# ----------------------------------------------------------------------
# Legacy (scripts/load-osm.sh) — still works if you want to run
# osm2pgsql outside docker. The init container ignores these; it reads
# PGHOST/PGUSER/etc. from the vars above via docker-compose.yml.
# ----------------------------------------------------------------------
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=maristmaps
PGPASSWORD=maristmaps
PGDATABASE=maristmaps
PBF_FILE=pbf/campus.osm.pbf
